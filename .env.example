# ══════════════════════════════════════════════════════
# ARMORY — Environment Variables
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# ══════════════════════════════════════════════════════

# Google OAuth
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Kakao OAuth
# https://developers.kakao.com → 내 애플리케이션 → 앱 키
KAKAO_REST_KEY=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here  # 선택 사항

# App
NEXTAUTH_URL=http://localhost:3000   # 배포 시 실제 도메인으로 변경
NEXTAUTH_SECRET=replace_with_32char_random_string

# Skin Analysis API (선택 — 없으면 Mock 모드)
SKIN_API_ENDPOINT=https://your-skin-api.com/v1/analyze
SKIN_API_KEY=your_api_key_here
